{
  "name": "eslint-plugin-bpmn-io",
  "version": "2.3.1",
  "description": "Shared lint rules for bpmn.io projects",
  "type": "module",
  "exports": {
    ".": "./index.js",
    "./configs/*.js": "./configs/*.js",
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/bpmn-io/eslint-plugin-bpmn-io.git"
  },
  "scripts": {
    "all": "npm test",
    "test": "npm test -w tests"
  },
  "keywords": [
    "eslint",
    "lint",
    "rules",
    "bpmn.io"
  ],
  "author": "Nico Rehwaldt <nico.rehwaldt@camunda.com>",
  "license": "MIT",
  "dependencies": {
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-mocha": "^11.3.0",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.6.0"
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "min-dash": "^5.0.0",
    "npm-run-all2": "^9.0.1"
  },
  "peerDependencies": {
    "eslint": "^9"
  },
  "files": [
    "configs",
    "index.js"
  ],
  "workspaces": [
    "test",
    "test/esm"
  ]
}
